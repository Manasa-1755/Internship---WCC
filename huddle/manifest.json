{
  "manifest_version": 3,
  "name": "Huddle Tracker",
  "version": "1.0.0",
  "description": "Track Google Chat huddle start time, end time, and duration with recording",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.google.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Huddle Tracker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["recorder.js"],
      "matches": ["https://chat.google.com/*", "https://mail.google.com/*"]
    }
  ]
}